  "keyFeatures": [
    "Declarative build metadata in build.yml with YAML schema validation",
    "OCI-hosted chart templates for reusable, versioned build stage implementations",
    "Docker Buildx Bake plan generation from metadata and chart dependencies",
    "Lock file support for pinned chart digests and drift detection",
    "Built-in plugins (NuGetAuthenticate, TestcontainersDinD) for CI environment setup",
    "Scaffolding via buildcharts init for .NET repositories",
    "Matrix expansion for multi-platform builds",
    "CI-provider-agnostic output via Docker-native Bake plans"
  ],
  "publicApiSurface": [
    "buildcharts init",
    "buildcharts update",
    "buildcharts generate [--use-inline-dockerfiles] [--ignore-lock] [--verbose]",
    "buildcharts pull <reference> [--untar] [--untardir <DIR>] [--output <OUTPUT>]",
    "buildcharts summary",
    "buildcharts version",
    "build.yml (version, variables, plugins, targets, types)",
    "charts/buildcharts/Chart.yaml (apiVersion, name, version, dependencies[name, alias, version, repository])",
    "charts/buildcharts/Chart.lock",
    "NuGetAuthenticate@v1 plugin",
    "TestcontainersDinD@v1 plugin"
  ]
}
